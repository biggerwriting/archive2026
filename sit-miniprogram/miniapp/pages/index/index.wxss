.container {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background: #0f0f23;
}

/* 摄像头全屏 */
.camera {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

/* Canvas 覆盖在摄像头上 */
.skeleton-canvas {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  pointer-events: none;
}

/* 底部状态面板 */
.panel {
  position: absolute;
  bottom: 120rpx;
  left: 20rpx;
  right: 20rpx;
  background: rgba(15, 15, 35, 0.88);
  border-radius: 24rpx;
  padding: 30rpx 36rpx;
  backdrop-filter: blur(20rpx);
  transition: border 0.3s;
}
.panel-ok {
  border: 2rpx solid #00c896;
}
.panel-alert {
  border: 2rpx solid #ff4757;
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%      { opacity: 0.7; }
}

.status-text {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.bar-wrapper {
  margin-top: 12rpx;
}
.bar {
  width: 100%;
  height: 18rpx;
  background: rgba(60, 60, 80, 0.6);
  border-radius: 9rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}
.bar-fill {
  height: 100%;
  border-radius: 9rpx;
  transition: width 0.2s;
}
.bar-good  { background: #00c896; }
.bar-hunch { background: #ff4757; }

.bar-label {
  font-size: 22rpx;
  color: #8888aa;
}

.timer {
  margin-top: 16rpx;
  font-size: 36rpx;
  color: #ff4757;
  font-weight: 700;
}

/* 底部按钮 */
.controls {
  position: absolute;
  bottom: 30rpx;
  left: 20rpx;
  right: 20rpx;
  display: flex;
  justify-content: center;
}
.btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: rgba(255, 255, 255, 0.12);
  color: #fff;
  font-size: 30rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10rpx);
}
