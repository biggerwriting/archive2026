{
  "manifest_version": 3,
  "name": "English Wordbook Helper",
  "version": "1.0.0",
  "description": "Save selected English words and example sentences from web pages.",
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["storage.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open Wordbook"
  },
  "options_page": "wordbook.html",
  "commands": {
    "add_selected_word": {
      "suggested_key": {
        "default": "Alt+Shift+A",
        "mac": "Alt+Shift+A"
      },
      "description": "Add selected word to wordbook"
    }
  }
}
