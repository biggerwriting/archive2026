{
  "manifest_version": 3,
  "name": "BOSS直聘职位收集器",
  "version": "1.0.0",
  "description": "浏览BOSS直聘时一键保存感兴趣的职位，并批量导出为CSV",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/sw.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "BOSS职位收集器",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.zhipin.com/*"],
      "js": ["content/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.zhipin.com/*"],
      "js": ["content/receiver.js"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://www.zhipin.com/*"]
}
